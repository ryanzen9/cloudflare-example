{
  "name": "cloudflare-workers-openapi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "install": "oxlint",
    "lint": "oxlint src/",
    "check": "oxfmt --check . && oxlint src/ && tsc",
    "format": "oxfmt . --write",
    "db:init": "wrangler d1 create cloudflare-example-db",
    "db:deploy": "wrangler d1 migrations apply cloudflare-example-db --local",
    "types": "wrangler types"
  },
  "dependencies": {
    "chanfana": "^3.3.0",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "wrangler": "^4.94.0"
  }
}
